---
import Layout from "@/layouts/Layout.astro";
import { Map } from "@/components/Map";
import {
    SidebarProvider as SidebarProviderL,
    SidebarTrigger as SidebarTriggerL,
} from "@/components/ui/sidebar-l";
import {
    SidebarProvider as SidebarProviderR,
    SidebarTrigger as SidebarTriggerR,
} from "@/components/ui/sidebar-r";
import { QuestionSidebar } from "@/components/QuestionSidebar";
import { ZoneSidebar } from "@/components/ZoneSidebar";
import { OptionDrawers } from "@/components/OptionDrawers";
import { TutorialManager } from "@/components/TutorialManager";
import { TimerDrawer } from "@/components/TimerDrawer";
import { NextStepsChecklist } from "@/components/NextStepsChecklist";
import { WelcomeDialog } from "@/components/WelcomeDialog";
---

<Layout className="bg-main">
    <WelcomeDialog client:only="react" />
    <TutorialManager client:only="react" />
    <NextStepsChecklist client:only="react" />
    <SidebarProviderL client:only="react" defaultOpen={false}>
        <SidebarProviderR client:only="react" defaultOpen={false}>
            <QuestionSidebar client:only="react" />
            <main class="flex flex-col flex-grow group">
                    <div class="w-full h-full relative">
                        <div
                            class="absolute top-[10px] left-1/2 -translate-x-1/2 z-[1030] group-[.fullscreen]:hidden"
                        >
                            <TimerDrawer client:only="react" />
                        </div>
                        <div
                            class="absolute top-[142px] left-[10px] z-[1030] group-[.fullscreen]:hidden" data-tutorial-id="left-sidebar-trigger"
                        >
                            <SidebarTriggerL client:only="react" />
                        </div>
                        <div
                            class="absolute top-[142px] right-[10px] z-[1030] group-[.fullscreen]:hidden" data-tutorial-id="right-sidebar-trigger"
                        >
                            <SidebarTriggerR client:only="react" />
                        </div>
                        <div class="absolute group-[.fullscreen]:hidden" data-tutorial-id="option-drawers-trigger"><OptionDrawers client:only="react" /></div>
                        <Map
                            className="w-full group-[.fullscreen]:w-full group-[.fullscreen]:h-full"
                            client:only="react"
                        />
                    </div>
            </main>
            <ZoneSidebar client:only="react" />
        </SidebarProviderR>
    </SidebarProviderL>
</Layout>
