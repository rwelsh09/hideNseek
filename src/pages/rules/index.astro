---
import Layout from "@/layouts/Layout.astro";
import { QUESTION_RULES } from "@/lib/rules";
---

<Layout className="bg-main text-white p-8">
  <div class="max-w-4xl mx-auto space-y-8 mt-12">
    <div class="flex items-center justify-between">
      <h1 class="text-4xl font-bold font-poppins">Rules & Tips</h1>
      <a href={`${import.meta.env.BASE_URL}`} class="text-blue-400 hover:text-blue-300">Back to Map</a>
    </div>

    <section class="space-y-4">
      <h2 class="text-2xl font-semibold border-b border-slate-700 pb-2">Question Rules</h2>
      <div class="grid gap-4 md:grid-cols-2">
        {Object.entries(QUESTION_RULES).map(([key, rule]) => (
          <div class="bg-slate-800 p-4 rounded-xl border border-slate-700">
            <h3 class="text-xl font-bold capitalize text-blue-400 mb-2">{key}</h3>
            <p class="text-slate-300">{rule}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="space-y-4">
      <h2 class="text-2xl font-semibold border-b border-slate-700 pb-2">General Tips</h2>
      <ul class="list-disc pl-6 space-y-2 text-slate-300">
        <li>The Time Penalty tracks how much extra time the Hider has to hide based on the questions you've locked.</li>
        <li>Use Playtest Mode to practice and refine your map layout.</li>
        <li>You can use the 'Follow Me' option to use your device's GPS for questions requiring your location.</li>
        <li>Make sure to use the correct question types to gather enough information about the Hider's location.</li>
        <li>Remember to 'Lock' a question once you've received your answer to calculate time penalties and finalize the map area!</li>
      </ul>
    </section>
  </div>
</Layout>
