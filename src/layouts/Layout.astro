---
import "@/styles/globals.css";
import { ToastContainer } from "react-toastify";
import { pwaInfo } from "virtual:pwa-info";

export interface Props {
    className?: string;
}

const { className } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <title>Hide and Seek - Calgary</title>
        
        <link
            rel="icon"
            type="image/svg+xml"
            href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/icon.svg`}
        />
        
        <script is:inline>
            // Run before anything else
            if (sessionStorage.getItem("resetEverything") === "true") {
                if ('caches' in window) {
                    caches.keys().then((keys) => {
                        keys.forEach((key) => {
                            caches.delete(key);
                        });
                    });
                }
                localStorage.clear();
                sessionStorage.removeItem("resetEverything");
            }

            // Catch the install prompt early before React hydrates
            window.addEventListener('beforeinstallprompt', (e) => {
                e.preventDefault();
                window.pwaDeferredPrompt = e;
                window.dispatchEvent(new Event('pwa-deferred-prompt-ready'));
            });
        </script>
        
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Oxygen:wght@300;400;700&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
            rel="stylesheet"
        />
        
        {pwaInfo && (
            <link
                rel="manifest"
                href={pwaInfo.webManifest.href}
                crossorigin={pwaInfo.webManifest.useCredentials ? "use-credentials" : undefined}
            />
        )}
        <script src="/src/pwa.ts"></script>
    </head>
    <body class:list={[className, "dark"]}>
        <slot />
        <ToastContainer
            client:only
            position="top-center"
            autoClose={2500}
            hideProgressBar={false}
            newestOnTop={false}
            closeOnClick={false}
            rtl={false}
            pauseOnFocusLoss={false}
            draggable
            pauseOnHover={false}
            theme="dark"
        />
    </body>
</html>
